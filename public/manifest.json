{
  "name": "Planner",
  "short_name": "Planner",
  "description": "Your Personal Planner — Study, Track, Achieve",
  "id": "/",
  "start_url": "/",
  "scope": "/",
  "scope_extensions": [
    {
      "origin": "https://planner.app"
    }
  ],
  "lang": "en-IN",
  "dir": "ltr",
  "display": "standalone",
  "display_override": ["standalone", "window-controls-overlay", "fullscreen"],
  "orientation": "portrait-primary",
  "background_color": "#0d0d1a",
  "theme_color": "#7c5cbf",
  "categories": ["education", "productivity", "utilities"],
  "iarc_rating_id": "e8c16b11-c1d5-4e2e-a1dd-9f9b8b3f7a2b",
  "prefer_related_applications": false,
  "related_applications": [
    {
      "platform": "webapp",
      "url": "https://planner.app/manifest.json"
    }
  ],
  "launch_handler": {
    "client_mode": "auto"
  },
  "note_taking": {
    "action": "/",
    "save_note": "/"
  },
  "edge_side_panel": {
    "preferred_width": 400
  },
  "share_target": {
    "action": "/",
    "method": "GET",
    "enctype": "application/x-www-form-urlencoded",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  },
  "protocol_handlers": [
    {
      "protocol": "web+planner",
      "url": "/?action=%s"
    }
  ],
  "file_handlers": [
    {
      "action": "/",
      "accept": {
        "text/plain": [".txt", ".md"],
        "application/json": [".json"]
      }
    }
  ],
  "shortcuts": [
    {
      "name": "New Task",
      "short_name": "Task",
      "description": "Add a new task",
      "url": "/?action=new-task",
      "icons": [
        {
          "src": "/icon-192x192.png",
          "sizes": "192x192",
          "type": "image/png"
        }
      ]
    },
    {
      "name": "Dashboard",
      "short_name": "Home",
      "description": "Go to dashboard",
      "url": "/",
      "icons": [
        {
          "src": "/icon-192x192.png",
          "sizes": "192x192",
          "type": "image/png"
        }
      ]
    }
  ],
  "icons": [
    {
      "src": "/icon-192x192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icon-512x512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icon-512x512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable"
    }
  ],
  "screenshots": [
    {
      "src": "/screenshots/dashboard.png",
      "sizes": "1080x1920",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "Dashboard overview showing tasks, tests, and revision schedule"
    },
    {
      "src": "/screenshots/dashboard-wide.png",
      "sizes": "1920x1080",
      "type": "image/png",
      "form_factor": "wide",
      "label": "Desktop dashboard with sidebar navigation and stats"
    }
  ],
  "widgets": [
    {
      "name": "Task Summary",
      "description": "Shows pending tasks count",
      "tag": "task-summary",
      "template": "widgets/task-summary.html",
      "ms_ac_template": "widgets/task-summary.msac",
      "data": "/api/widget/tasks",
      "type": "application/json",
      "screenshots": [
        {
          "src": "/icon-512x512.png",
          "sizes": "512x512",
          "type": "image/png",
          "label": "Task widget preview"
        }
      ]
    }
  ]
}
